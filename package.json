{
  "name": "highlights",
  "version": "1.0.0",
  "description": "![Screenshot of the website](assets/images/screenshot.png?raw=true)",
  "main": ".eleventy.js",
  "scripts": {
    "sass": "pnpm exec sass --style=compressed assets/_sass/style.scss assets/css/style.css",
    "watch:sass": "pnpm exec sass --style=compressed assets/_sass/style.scss assets/css/style.css --watch",
    "watch:eleventy": "pnpm exec eleventy --serve",
    "dev": "npm-run-all sass --parallel watch:*",
    "build": "pnpm exec eleventy",
    "update": "uv run python scripts/update.py"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/felixzieger/highlights.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/melanierichards/highlights/issues"
  },
  "homepage": "https://github.com/melanierichards/highlights#readme",
  "dependencies": {
    "@11ty/eleventy": "^3.1.6",
    "js-yaml": "^5.0.0",
    "npm-run-all": "^4.1.5",
    "sass": "^1.101.0"
  }
}
